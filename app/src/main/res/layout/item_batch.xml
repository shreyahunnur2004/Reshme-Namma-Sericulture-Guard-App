<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/card_peach_border">

        <!-- Left color strip -->
        <View
            android:id="@+id/viewStrip"
            android:layout_width="4dp"
            android:layout_height="56dp"
            android:background="#F4A58A"
            android:layout_marginEnd="14dp"/>

        <!-- Batch Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBatchName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Batch Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3D1A0A"
                android:fontFamily="serif"/>

            <TextView
                android:id="@+id/tvBreed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breed"
                android:textSize="12sp"
                android:textColor="#C4825A"
                android:layout_marginTop="3dp"/>

            <TextView
                android:id="@+id/tvDaysInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day 1 · Instar 1"
                android:textSize="11sp"
                android:textColor="#F4A58A"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- Badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            android:textSize="10sp"
            android:textColor="#7A3A22"
            android:textStyle="bold"
            android:background="@drawable/badge_active"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>