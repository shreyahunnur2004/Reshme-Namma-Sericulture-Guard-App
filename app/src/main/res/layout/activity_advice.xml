<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F4">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F4A58A"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysis complete"
            android:textSize="12sp"
            android:textColor="#7A3A22"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Climate Result"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3D1A0A"
            android:fontFamily="serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- Status Circle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvStatusCircle"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/circle_background"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:id="@+id/tvStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B50"
                    android:fontFamily="serif"/>

                <TextView
                    android:id="@+id/tvInstarLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instar 1"
                    android:textSize="12sp"
                    android:textColor="#C4825A"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Readings Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:background="@drawable/card_peach_border">

                    <!-- Temp -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temperature"
                            android:textSize="10sp"
                            android:textColor="#C4825A"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvTempReading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°C"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#3D1A0A"
                            android:fontFamily="serif"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#F2C9B8"/>

                    <!-- Humidity -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Humidity"
                            android:textSize="10sp"
                            android:textColor="#C4825A"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvHumidityReading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#3D1A0A"
                            android:fontFamily="serif"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Advice Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/card_peach_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Advice"
                        android:textSize="10sp"
                        android:textColor="#C4825A"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvAdvice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:textColor="#3D1A0A"
                        android:lineSpacingExtra="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Back to Home"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3D1A0A"
                android:backgroundTint="#F4A58A"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>