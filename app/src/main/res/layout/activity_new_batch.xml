<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F4">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F4A58A"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New rearing cycle"
            android:textSize="12sp"
            android:textColor="#7A3A22"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start New Batch"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3D1A0A"
            android:fontFamily="serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Batch Name Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@drawable/card_peach_border">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="🏠"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="@drawable/icon_bg_peach2"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Batch Name"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#3D1A0A"
                                android:fontFamily="serif"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="House or batch label"
                                android:textSize="11sp"
                                android:textColor="#C4825A"/>

                        </LinearLayout>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etBatchName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="e.g. House A – Batch 3"
                        android:inputType="text"
                        android:textSize="13sp"
                        android:textColor="#3D1A0A"
                        android:background="@drawable/input_peach"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Breed Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@drawable/card_peach_border">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="🐛"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="@drawable/icon_bg_peach"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Silkworm Breed"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#3D1A0A"
                                android:fontFamily="serif"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Type of variety"
                                android:textSize="11sp"
                                android:textColor="#C4825A"/>

                        </LinearLayout>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etBreed"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="e.g. PM×CSR, Pure Mysore"
                        android:inputType="text"
                        android:textSize="13sp"
                        android:textColor="#3D1A0A"
                        android:background="@drawable/input_peach"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Date Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@drawable/card_peach_border">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="📅"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="@drawable/icon_bg_peach2"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start Date"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#3D1A0A"
                                android:fontFamily="serif"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="When did rearing begin?"
                                android:textSize="11sp"
                                android:textColor="#C4825A"/>

                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnPickDate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Tap to select date"
                        android:textColor="#C4825A"
                        android:textSize="13sp"
                        android:backgroundTint="#FEF0E8"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveBatch"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Batch"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3D1A0A"
                android:backgroundTint="#F4A58A"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>