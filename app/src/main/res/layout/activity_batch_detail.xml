<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Harvest Banner -->
        <TextView
            android:id="@+id/tvHarvestBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎉 Time to Harvest! Transfer cocoons to spinning trays now."
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="#E65100"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- Batch Name -->
        <TextView
            android:id="@+id/tvBatchName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batch Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvBreed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Breed"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="24dp"/>

        <!-- Day and Instar Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvDayCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day 1"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"/>

                <TextView
                    android:id="@+id/tvInstar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instar 1"
                    android:textSize="20sp"
                    android:textColor="#558B2F"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ideal Conditions Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDEAL CONDITIONS"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvIdealTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ideal Temp: --"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvIdealHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ideal Humidity: --"
                    android:textSize="16sp"
                    android:textColor="#333333"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Log Climate Button -->
        <Button
            android:id="@+id/btnLogClimate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📊 Log Climate Now"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"/>

    </LinearLayout>
</ScrollView>