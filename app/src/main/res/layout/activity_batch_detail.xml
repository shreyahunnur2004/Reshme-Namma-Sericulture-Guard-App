<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F4">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F4A58A"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="22dp">

        <TextView
            android:id="@+id/tvBreed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Breed"
            android:textSize="12sp"
            android:textColor="#7A3A22"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvBatchName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batch Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3D1A0A"
            android:fontFamily="serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Harvest Banner -->
            <TextView
                android:id="@+id/tvHarvestBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎉  Time to Harvest! Transfer cocoons to spinning trays now."
                android:textSize="13sp"
                android:textColor="#7A3A22"
                android:background="#FDE8DC"
                android:padding="16dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone"/>

            <!-- Day and Instar Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/card_peach_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Stage"
                        android:textSize="10sp"
                        android:textColor="#C4825A"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDayCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Day 1"
                                android:textSize="38sp"
                                android:textStyle="bold"
                                android:textColor="#3D1A0A"
                                android:fontFamily="serif"
                                android:lineSpacingExtra="0dp"/>

                            <TextView
                                android:id="@+id/tvInstar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Instar 1"
                                android:textSize="14sp"
                                android:textColor="#C4825A"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="🌿"
                            android:textSize="22sp"
                            android:gravity="center"
                            android:background="@drawable/icon_bg_peach"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ideal Conditions Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/card_peach_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ideal Conditions"
                        android:textSize="10sp"
                        android:textColor="#C4825A"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="16dp"/>

                    <!-- Temp Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="🌡️"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="@drawable/icon_bg_peach"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Temperature"
                            android:textSize="12sp"
                            android:textColor="#C4825A"/>

                        <TextView
                            android:id="@+id/tvIdealTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#3D1A0A"
                            android:fontFamily="serif"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F2C9B8"
                        android:layout_marginBottom="14dp"/>

                    <!-- Humidity Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="💧"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="@drawable/icon_bg_peach2"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Humidity"
                            android:textSize="12sp"
                            android:textColor="#C4825A"/>

                        <TextView
                            android:id="@+id/tvIdealHumidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#3D1A0A"
                            android:fontFamily="serif"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Log Climate Button -->
            <Button
                android:id="@+id/btnLogClimate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Log Climate Now"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3D1A0A"
                android:backgroundTint="#F4A58A"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>