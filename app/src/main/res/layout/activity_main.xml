<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reshme Namma Pride"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Silk Farming"
            android:textSize="14sp"
            android:textColor="#558B2F"
            android:layout_marginBottom="24dp"/>

        <!-- Active Batch Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardActiveBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvActiveBatchTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Batch"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvActiveBatchInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No active batch"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvInstarInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#558B2F"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Start New Batch Button -->
        <Button
            android:id="@+id/btnNewBatch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="＋  Start New Batch"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="12dp"/>

        <!-- View My Batches Button -->
        <Button
            android:id="@+id/btnViewBatches"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📋  View My Batches"
            android:textSize="16sp"
            android:textColor="#2E7D32"
            android:backgroundTint="#C8E6C9"
            android:layout_marginBottom="20dp"/>

        <!-- Climate Notice -->
        <TextView
            android:id="@+id/tvClimateNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Climate not logged today"
            android:textSize="14sp"
            android:textColor="#E65100"
            android:background="#FFF3E0"
            android:padding="12dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>